{
  "name": "vapurl",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "gen-config": "envsubst '$VAPURL_KV_ID $VAPURL_API_KEY' < wrangler.template.toml > wrangler.toml",
    "preview": "$npm_execpath run gen-config && $npm_execpath run build && vite preview",
    "deploy": "$npm_execpath run gen-config && $npm_execpath run build && wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.26.1",
    "@cloudflare/workers-types": "^4.20260307.1",
    "@hono/vite-dev-server": "^0.25.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.27",
    "hono": "^4.12.7",
    "postcss": "^8.5.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.19",
    "vite": "^7.3.1",
    "vite-ssr-components": "^0.5.2",
    "wrangler": "^4.17.0",
    "ws": "^8.19.0"
  }
}
